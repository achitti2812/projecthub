# PostgreSQL connection string
# For Neon (recommended with Vercel): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# For local dev: postgresql://devuser:devpass@localhost:5432/projectmgmt
DATABASE_URL="postgresql://user:password@localhost:5432/projectmgmt"

# JWT secret for authentication (use a long random string in production)
JWT_SECRET="your-jwt-secret"

# Server port (only used for local dev, ignored on Vercel)
PORT=4000
